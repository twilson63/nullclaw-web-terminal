# Deno Deploy token — required
# Obtain from https://console.deno.com
DENO_DEPLOY_TOKEN=deno_dp_xxx

# Snapshot slug created during Phase 0 (default: nullclaw-snapshot)
NULLCLAW_SNAPSHOT=nullclaw-snapshot

# Deno Sandbox region — must match the snapshot region (default: ord)
DENO_REGION=ord

# LLM provider API key — required, injected into sandbox as a secret
LLM_API_KEY=sk-or-v1-...

# LLM API host — used for secret host binding (default: openrouter.ai)
# IMPORTANT: Must match the actual API host. The secrets proxy only intercepts
# TLS for this host. Other outbound connections go direct (needed for web search).
LLM_API_HOST=openrouter.ai

# LLM provider for NullClaw (default: openrouter)
LLM_PROVIDER=openrouter

# LLM model for NullClaw (default: anthropic/claude-sonnet-4)
LLM_MODEL=anthropic/claude-sonnet-4

# Server port (default: 3000)
PORT=3000

# Maximum number of concurrent sandbox sessions (default: 5)
MAX_CONCURRENT_SESSIONS=5

# Session time-to-live in minutes before auto-kill (default: 30)
SESSION_TTL_MINUTES=30
